MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/zynsource?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-string
PORT=4000
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=http://localhost:4000

# Phase 2A — optional. Features auto-disable if missing.
# OPENAI_API_KEY=sk-proj-...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=zynsource-s3-bucket

# Phase 2B — admin allowlist for verified-employer flips, blog write, etc.
# ADMIN_EMAILS=you@example.com,partner@example.com

# Phase 2C — SMTP for nodemailer. Use Brevo (300/day free) OR Gmail (App Password).
# Brevo: https://app.brevo.com/settings/keys/smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# EMAIL_FROM=ZynSource <noreply@yourdomain.com>

# Phase 2E — optional observability (free tiers).
# SENTRY_DSN=
# POSTHOG_KEY=
