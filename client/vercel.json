{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://zynsource.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://zynsource.onrender.com/uploads/$1" },
    { "source": "/sitemap.xml", "destination": "https://zynsource.onrender.com/sitemap.xml" },
    { "source": "/robots.txt", "destination": "https://zynsource.onrender.com/robots.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
